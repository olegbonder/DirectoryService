{
  "DeleteExpiredDepartmentHours": 24,
  "ConnectionStrings": {
    "FileServiceDb": "Host=localhost;Port=5437;Database=file_service_db;User Id=postgres;Password=postgres;"
  },
  "S3Options": {
    "Endpoint": "http://localhost:9000",
    "AccessKey": "minioadmin",
    "SecretKey": "minioadmin",
    "WithSsl": false,
    "DownloadExpirationHours": 24,
    "RequiredBuckets": ["videos", "preview"],
    "UploadUrlExpirationMinutes": 30,
    "MaxConcurrentRequests": 20
  },
  "VideoProcessing": {
    "FfmpegPath": "C:/ffmpeg/bin/ffmpeg.exe",
    "FfprobePath":"C:/ffmpeg/bin/ffprobe.exe",
    "UseHardwareAcceleration": false,
    "VideoEncoder": "libx264",
    "VideoPreset": "medium",
    "UploadDegreeOfParallelism": 10,
    "MaxRetries": 3,
    "RetryDelaySeconds": 3
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.AspNetCore": "Information",
        "Microsoft.AspNetCore.Hosting": "Information",
        "Microsoft.AspNetCore.Routing": "Warning",
        "Microsoft.EntityFrameworkCore": "Information",
        "Microsoft.EntityFrameworkCore.Database.Command": "Information",
        "Microsoft.EntityFrameworkCore.Query": "Debug",
        "Microsoft.EntityFrameworkCore.Infrastructure": "Warning",
        "System": "Information",
        "System.Net.Http.HttpClient": "Information",
        "Hangfire": "Information",
        "Application": "Debug"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss.fff} {Level:u3}] {SourceContext:l} {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5342"
        }
      },
      {
        "Name": "Debug"
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithEnvironmentName",
      "WithThreadId",
      "WithExceptionDetails"
    ]
  },

  "AllowedHosts": "*"
}
